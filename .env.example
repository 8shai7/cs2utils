# Copy to .env and fill in. On Hostinger, use the MySQL host/name/user/password
# from hPanel → Databases → MySQL Databases.

PORT=3001

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=cs2utils
DB_PASSWORD=change_me
DB_NAME=cs2utils
# Optional: DB_CONNECT_TIMEOUT_MS=20000  DB_INIT_RETRIES=3
#
# Vercel / any remote host: DB_HOST must be a publicly reachable MySQL hostname
# (not 127.0.0.1). Hostinger → Databases → Remote MySQL: enable access (allow %
# if the host has rotating IPs like Vercel). Prefer running the full Node app on
# Hostinger itself with DB_HOST=localhost when MySQL is on the same machine.

# Secret used to sign login tokens. Use a long random string in production.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=change_me_to_a_long_random_string

# Public URLs (production). Used for password-reset links + the Steam login redirect.
APP_URL=https://aimkit.net
API_URL=https://aimkit.net

# Whoever registers/logs in with this email is granted the owner role (admin).
OWNER_EMAIL=shaital121@gmail.com

# Comma-separated allowed origins for the browser app, or * for any.
CORS_ORIGIN=*

# Where uploaded images are stored (relative to the server folder).
UPLOAD_DIR=uploads

# ImgBB API key for profile-picture hosting (https://api.imgbb.com/).
IMGBB_API_KEY=your_imgbb_api_key

# Steam Web API key (https://steamcommunity.com/dev/apikey) — for Steam login
# (fetches the player's persona name + avatar). Set both to the same key.
STEAM_API_KEY=your_steam_api_key
STEAM_WEB_API_KEY=your_steam_api_key

# Contact form email. Messages are always stored in the DB; if SMTP is set they
# are also emailed to CONTACT_TO. On Hostinger use your mailbox SMTP settings.
CONTACT_TO=service@aimkit.net
MAIL_FROM=service@aimkit.net
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=service@aimkit.net
SMTP_PASS=your_mailbox_password

# Optional: auto-update the command catalog from a remote JSON feed (a wiki
# export). Leave empty to use the built-in curated seed only. The feed must be a
# JSON array (or {"commands":[...]}) of objects:
#   { "key": "lo-novid", "category": "launch", "type": "launch",
#     "command": "-novid", "title": "...", "description": "...", "sort": 0 }
# When set, the catalog refreshes on startup + every COMMANDS_SYNC_TTL_HOURS,
# and admins can trigger a manual sync from the Commands tab.
COMMANDS_SOURCE_URL=
COMMANDS_SYNC_TTL_HOURS=24
